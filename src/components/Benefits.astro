---
const benefits = [
	{
		title: "Без зайвого шуму",
		text: "Не обіцяємо золотих гір. Говоримо прямо, робимо чітко, здаємо в строк."
	},
	{
		title: "Сайт + бот + CRM",
		text: "Зв’язуємо інструменти в систему, щоб заявки не губились, а робота рухалась."
	},
	{
		title: "Менше хаосу. Більше контролю.",
		text: "Автоматизуємо рутину, наводимо порядок у процесах і даних."
	},
	{
		title: "Підтримка по ділу",
		text: "Не зникаємо після запуску. Допомагаємо розвивати те, що працює."
	}
];
---
<section class="benefits">
	<div class="container">
		<div class="benefits__grid">
			{benefits.map(benefit => (
				<div class="brutal-card benefit-card">
					<div class="benefit-card__icon lime-dot"></div>
					<h3 class="benefit-card__title">{benefit.title}</h3>
					<p class="benefit-card__text">{benefit.text}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.benefits__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.benefit-card {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		min-height: 250px;
	}

	.benefit-card__title {
		font-size: 1.8rem;
		line-height: 1.1;
	}

	.benefit-card__text {
		font-size: 1.1rem;
		font-weight: 500;
		opacity: 0.8;
	}
</style>
