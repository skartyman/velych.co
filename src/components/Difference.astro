---
const comparison = [
	{
		old: "Красиві обіцянки та шаблонні рішення",
		new: "Чесна розмова і рішення під задачу"
	},
	{
		old: "Роблять сайт і зникають",
		new: "Будуємо систему і залишаємось поруч"
	},
	{
		old: "Терміни зриваються, процес непрозорий",
		new: "Фіксуємо строки й тримаємо в курсі"
	},
	{
		old: "Заявки приходять, але губляться",
		new: "Заявки обробляються і стають клієнтами"
	},
	{
		old: "Немає інтеграцій і автоматизації",
		new: "Інтегруємо сайт, бота, CRM та аналітику"
	},
	{
		old: "Ви платите за години",
		new: "Ви отримуєте результат і зростання"
	}
];
---
<section class="difference">
	<div class="container">
		<h2 class="section-title">Чому ми?</h2>
		
		<div class="comparison-block corner-bracket">
			<div class="comp-header">
				<div class="comp-header__col">Типова студія</div>
				<div class="comp-header__col">VELYCH.CO</div>
			</div>
			
			<div class="comp-body">
				{comparison.map(item => (
					<div class="comp-row">
						<div class="comp-col comp-col--old">{item.old}</div>
						<div class="comp-col comp-col--arrow">→</div>
						<div class="comp-col comp-col--new">{item.new}</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.section-title {
		font-size: clamp(2.5rem, 5vw, 4rem);
		margin-bottom: 4rem;
		text-align: center;
	}

	.comparison-block {
		background-color: var(--color-white);
		border: var(--border-width) solid var(--color-black);
	}

	.comp-header {
		display: grid;
		grid-template-columns: 1fr 1fr;
		background-color: var(--color-black);
		color: var(--color-white);
		font-weight: 800;
		text-transform: uppercase;
		font-size: 1.1rem;
		letter-spacing: 0.05em;
	}

	.comp-header__col {
		padding: 1.5rem 3rem;
		border-right: 1px solid rgba(255,255,255,0.2);
	}

	.comp-header__col:last-child {
		border-right: none;
		color: var(--color-lime);
	}

	.comp-row {
		display: grid;
		grid-template-columns: 1fr 50px 1fr;
		border-bottom: 1px solid rgba(0,0,0,0.1);
		transition: var(--transition);
	}

	.comp-row:last-child {
		border-bottom: none;
	}

	.comp-row:hover {
		background-color: rgba(200, 255, 0, 0.05);
	}

	.comp-col {
		padding: 2rem 3rem;
		font-size: 1.1rem;
		font-weight: 600;
		display: flex;
		align-items: center;
	}

	.comp-col--arrow {
		justify-content: center;
		color: var(--color-lime);
		font-weight: 900;
		padding: 0;
	}

	.comp-col--old {
		opacity: 0.5;
	}

	.comp-col--new {
		background-color: rgba(200, 255, 0, 0.02);
	}

	@media (max-width: 1024px) {
		.comp-col {
			padding: 1.5rem;
		}
	}

	@media (max-width: 768px) {
		.comp-header {
			display: none;
		}

		.comp-row {
			grid-template-columns: 1fr;
			padding: 2rem;
			gap: 0.5rem;
		}

		.comp-col {
			padding: 0.5rem 0;
		}

		.comp-col--old::before {
			content: "Типово: ";
			font-size: 0.7rem;
			text-transform: uppercase;
			display: block;
			width: 100%;
			margin-bottom: 0.2rem;
		}
		
		.comp-col--old {
			flex-direction: column;
			align-items: flex-start;
		}

		.comp-col--new::before {
			content: "VELYCH.CO: ";
			font-size: 0.7rem;
			text-transform: uppercase;
			display: block;
			margin-bottom: 0.2rem;
			color: var(--color-black);
		}

		.comp-col--new {
			background-color: var(--color-lime);
			padding: 1rem;
			margin-top: 0.5rem;
			flex-direction: column;
			align-items: flex-start;
		}

		.comp-col--arrow {
			display: none;
		}
	}
</style>
