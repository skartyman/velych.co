---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---
<footer class="footer section-dark">
	<div class="container footer__inner">
		<div class="footer__main">
			<div class="footer__logo-block">
				<Logo variant="dark" />
				<p class="footer__tagline">Ми будуємо інструменти для тих, хто цінує результат більше, ніж картинку.</p>
			</div>
			
			<div class="footer__nav">
				<div class="footer__nav-group">
					<span class="footer__nav-label">Навігація</span>
					<ul class="footer__nav-list">
						<li><a href="/posluhy">Послуги</a></li>
						<li><a href="/proiekty">Проєкти</a></li>
						<li><a href="/pidkhid">Підхід</a></li>
						<li><a href="/kontakty">Контакти</a></li>
					</ul>
				</div>
				<div class="footer__nav-group">
					<span class="footer__nav-label">Зв'язок</span>
					<ul class="footer__nav-list">
						<li><a href="mailto:hello@velych.pp.ua">hello@velych.pp.ua</a></li>
						<li><a href="#">Telegram</a></li>
						<li><a href="#">LinkedIn</a></li>
					</ul>
				</div>
			</div>
		</div>
		
		<div class="footer__bottom">
			<div class="footer__copyright">
				&copy; {year} VELYCH.CO. <span class="footer__marker">///</span> ЗРОБЛЕНО В УКРАЇНІ
			</div>
			<div class="footer__legal">
				<a href="/privacy">Privacy Policy</a>
			</div>
		</div>
	</div>
</footer>

<style>
	.footer {
		padding-bottom: 4rem;
	}

	.footer__inner {
		display: flex;
		flex-direction: column;
		gap: 6rem;
	}

	.footer__main {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 4rem;
	}

	.footer__logo-block {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.footer__tagline {
		font-size: 1.2rem;
		max-width: 400px;
		opacity: 0.6;
		font-weight: 500;
	}

	.footer__nav {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
	}

	.footer__nav-group {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.footer__nav-label {
		font-size: 0.75rem;
		text-transform: uppercase;
		font-weight: 800;
		opacity: 0.3;
		letter-spacing: 0.1em;
	}

	.footer__nav-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
	}

	.footer__nav-list a {
		font-weight: 700;
		font-size: 1.1rem;
		opacity: 0.8;
	}

	.footer__nav-list a:hover {
		opacity: 1;
		color: var(--color-lime);
	}

	.footer__bottom {
		padding-top: 3rem;
		border-top: 1px solid rgba(255,255,255,0.1);
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.85rem;
		font-weight: 600;
		opacity: 0.5;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.footer__marker {
		color: var(--color-lime);
		margin: 0 0.5rem;
	}

	@media (max-width: 1024px) {
		.footer__main {
			grid-template-columns: 1fr;
			gap: 4rem;
		}
	}

	@media (max-width: 768px) {
		.footer__bottom {
			flex-direction: column;
			gap: 1.5rem;
			text-align: center;
		}
		
		.footer__nav {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
	}
</style>
