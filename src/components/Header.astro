---
import Logo from './Logo.astro';
---
<header class="header">
	<div class="container header__inner">
		<div class="header__left">
			<a href="/" class="header__logo">
				<Logo variant="light" />
			</a>
			<span class="header__descriptor">веб-розробка з характером</span>
		</div>
		
		<nav class="nav">
			<ul class="nav__list">
				<li><a href="/posluhy">Послуги</a></li>
				<li><a href="/proiekty">Проєкти</a></li>
				<li><a href="/pidkhid">Підхід</a></li>
				<li><a href="/kontakty">Контакти</a></li>
			</ul>
		</nav>

		<div class="header__right">
			<a href="#form" class="btn btn-sm btn-discuss">Обговорити проєкт →</a>
			<button class="burger" aria-label="Menu">
				<span></span>
				<span></span>
				<span></span>
			</button>
		</div>
	</div>
</header>

<style>
	.header {
		padding: 1rem 0;
		background-color: var(--color-milk);
		position: sticky;
		top: 0;
		z-index: 1000;
		border-bottom: var(--border-width) solid rgba(0,0,0,0.1);
	}

	.header__inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.header__left {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.header__descriptor {
		font-size: 0.75rem;
		text-transform: uppercase;
		font-weight: 700;
		opacity: 0.5;
		letter-spacing: 0.05em;
		max-width: 100px;
		line-height: 1.1;
	}

	.nav__list {
		display: flex;
		list-style: none;
		gap: 2.5rem;
	}

	.nav__list a {
		font-weight: 700;
		text-transform: uppercase;
		font-size: 0.85rem;
		letter-spacing: 0.02em;
	}

	.nav__list a:hover {
		color: var(--color-lime);
		-webkit-text-stroke: 0.5px var(--color-black);
	}

	.header__right {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.btn-sm {
		padding: 0.6rem 1.2rem;
		font-size: 0.75rem;
	}

	.burger {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 5px;
	}

	.burger span {
		display: block;
		width: 24px;
		height: 2px;
		background-color: var(--color-black);
	}

	@media (max-width: 1024px) {
		.nav, .header__descriptor {
			display: none;
		}
		
		.burger {
			display: flex;
		}
	}

	@media (max-width: 480px) {
		.btn-discuss {
			display: none;
		}
	}
</style>
