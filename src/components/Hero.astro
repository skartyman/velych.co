---
---
<section class="hero">
	<div class="container hero__inner">
		<div class="hero__content">
			<div class="hero__badge outline-badge">Web Engineering Agency</div>
			<h1 class="hero__title">
				Не тільки<br/>
				<span class="text-stroke">WOW!!!</span><br/>
				<span class="bg-lime">А ще й робочі</span><br/>
				<span>інструменти</span>
			</h1>
			<p class="hero__description">
				Красиво — обов’язково. Але спочатку все повинно працювати.
			</p>
			<div class="hero__actions">
				<a href="#form" class="btn btn-primary">Обговорити проєкт <span class="arrow">→</span></a>
				<a href="#process" class="btn">Показати, як це працює</a>
			</div>
		</div>
		
		<div class="hero__visual">
			<div class="cube-wrapper corner-bracket">
				<img 
					src="/images/brand/concrete-cube.webp" 
					alt="VELYCH.CO Concrete Cube" 
					class="hero__image"
					width="560"
					height="700"
					loading="eager"
					fetchpriority="high"
				/>
				<div class="cube-text">КОД МАЄ ПРАЦЮВАТИ…</div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		background-color: var(--color-white);
		min-height: 90vh;
		display: flex;
		align-items: center;
		padding: 4rem 0;
		position: relative;
		overflow: hidden;
	}

	.hero__inner {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 4rem;
		align-items: center;
	}

	.hero__badge {
		margin-bottom: 2rem;
		color: var(--color-black);
		opacity: 0.6;
	}

	.hero__title {
		font-size: clamp(3rem, 10vw, 6.5rem);
		line-height: 0.85;
		margin-bottom: 2.5rem;
	}

	.text-stroke {
		color: transparent;
		-webkit-text-stroke: 2px var(--color-black);
	}

	.bg-lime {
		background-color: var(--color-lime);
		padding: 0 0.2em;
		display: inline-block;
	}

	.hero__description {
		font-size: clamp(1.1rem, 2.5vw, 1.5rem);
		font-weight: 500;
		max-width: 600px;
		margin-bottom: 3.5rem;
		opacity: 0.8;
	}

	.hero__actions {
		display: flex;
		gap: 1.5rem;
	}

	.hero__visual {
		position: relative;
		display: flex;
		justify-content: flex-end;
	}

	.cube-wrapper {
		position: relative;
		display: inline-block;
	}

	.hero__image {
		max-width: 100%;
		height: auto;
		display: block;
		filter: grayscale(1);
		mix-blend-mode: multiply;
	}

	.cube-text {
		position: absolute;
		bottom: 10%;
		left: -20px;
		background-color: var(--color-black);
		color: var(--color-lime);
		padding: 0.5rem 1rem;
		font-weight: 800;
		font-size: 0.9rem;
		transform: rotate(-90deg);
		transform-origin: left bottom;
		white-space: nowrap;
		letter-spacing: 0.1em;
	}

	@media (max-width: 1024px) {
		.hero__inner {
			grid-template-columns: 1fr;
			gap: 5rem;
		}
		
		.hero__visual {
			order: 2;
			justify-content: center;
		}
	}

	@media (max-width: 768px) {
		.hero__actions {
			flex-direction: column;
		}
		
		.hero__title {
			font-size: clamp(2.5rem, 12vw, 4rem);
		}
	}
</style>
