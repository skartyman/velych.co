---
---
<section class="lead-form section-dark" id="form">
	<div class="container">
		<div class="form-grid">
			<div class="form-content">
				<h2 class="form-title">Обговорити проєкт</h2>
				<p class="form-subtitle">Заповніть форму, і ми підготуємо пропозицію для вашого бізнесу.</p>
				
				<div class="form-contacts">
					<div class="contact-item">
						<span class="contact-label">Email:</span>
						<a href="mailto:hello@velych.pp.ua" class="contact-value">hello@velych.pp.ua</a>
					</div>
					<div class="contact-item">
						<span class="contact-label">Telegram:</span>
						<span class="contact-value">@velych_co</span>
					</div>
				</div>
			</div>

			<div class="form-wrapper corner-bracket">
				<form class="form" id="contact-form">
					<!-- Honeypot -->
					<div class="hp-field">
						<label for="company">Company</label>
						<input type="text" id="company" name="company" tabindex="-1" autocomplete="off" />
					</div>

					<div class="form__group">
						<label for="name">Ім’я</label>
						<input type="text" id="name" name="name" placeholder="Як вас звати?" required />
					</div>
					
					<div class="form__group">
						<label for="contact">Контакт</label>
						<input type="text" id="contact" name="contact" placeholder="Telegram або телефон" required />
					</div>
					
					<div class="form__group">
						<label for="type">Що потрібно?</label>
						<select id="type" name="type" required>
							<option value="" disabled selected>Оберіть варіант</option>
							<option value="Веб-сайт">Веб-сайт</option>
							<option value="Telegram-бот">Telegram-бот</option>
							<option value="CRM / Адмін-панель">CRM / Адмін-панель</option>
							<option value="Автоматизація">Автоматизація</option>
							<option value="Інше">Інше</option>
						</select>
					</div>
					
					<div class="form__group">
						<label for="message">Опис задачі</label>
						<textarea id="message" name="message" rows="4" placeholder="Розкажіть коротко про ваш проєкт (мін. 5 символів)" required minlength="5"></textarea>
					</div>
					
					<button type="submit" class="btn btn-primary" id="submit-btn">
						Відправити запит <span class="arrow">→</span>
					</button>
					<p class="error-msg" id="form-error"></p>
				</form>
				
				<div class="form-success" id="form-success" style="display: none;">
					<div class="success-icon">✓</div>
					<h3>Дякуємо. Заявку відправлено.</h3>
					<p>Ми зв’яжемося з вами найближчим часом.</p>
					<button class="btn btn-sm" id="form-reset">Відправити ще одну</button>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement;
	const success = document.getElementById('form-success');
	const reset = document.getElementById('form-reset');
	const errorMsg = document.getElementById('form-error');
	const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		if (errorMsg) errorMsg.innerText = '';
		if (submitBtn) {
			submitBtn.disabled = true;
			submitBtn.innerText = 'Відправка...';
		}

		const formData = new FormData(form);
		const data = {
			name: formData.get('name'),
			contact: formData.get('contact'),
			need: formData.get('type'),
			message: formData.get('message'),
			company: formData.get('company')
		};

		try {
			const response = await fetch('/api/lead', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(data)
			});

			const result = await response.json();

			if (response.ok && result.ok) {
				form.style.display = 'none';
				if (success) success.style.display = 'flex';
			} else {
				if (errorMsg) {
					errorMsg.innerText = result.ok === false && result.message === "Lead was received, but Telegram notification failed" 
						? "Дякуємо. Заявку отримано, але виникла технічна затримка з повідомленням."
						: "Не вдалося відправити заявку. Напишіть нам напряму: hello@velych.pp.ua";
				}
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.innerHTML = 'Відправити запит <span class="arrow">→</span>';
				}
			}
		} catch (error) {
			if (errorMsg) errorMsg.innerText = 'Не вдалося відправити заявку. Напишіть нам напряму: hello@velych.pp.ua';
			if (submitBtn) {
				submitBtn.disabled = false;
				submitBtn.innerHTML = 'Відправити запит <span class="arrow">→</span>';
			}
		}
	});

	reset?.addEventListener('click', () => {
		if (success) success.style.display = 'none';
		form.style.display = 'flex';
		form.reset();
		if (submitBtn) {
			submitBtn.disabled = false;
			submitBtn.innerHTML = 'Відправити запит <span class="arrow">→</span>';
		}
	});
</script>

<style>
	.form-grid {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 6rem;
		align-items: center;
	}

	.form-title {
		font-size: clamp(2.5rem, 5vw, 4.5rem);
		margin-bottom: 2rem;
	}

	.form-subtitle {
		font-size: 1.2rem;
		opacity: 0.6;
		margin-bottom: 4rem;
		max-width: 400px;
	}

	.form-contacts {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.contact-item {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.contact-label {
		font-size: 0.75rem;
		text-transform: uppercase;
		font-weight: 800;
		opacity: 0.4;
	}

	.contact-value {
		font-size: 1.5rem;
		font-weight: 700;
	}

	.form-wrapper {
		background-color: var(--color-white);
		padding: 4rem;
		color: var(--color-black);
	}

	.hp-field {
		display: none;
	}

	.form {
		display: flex;
		flex-direction: column;
		gap: 1.8rem;
	}

	.form__group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.form__group label {
		font-weight: 800;
		text-transform: uppercase;
		font-size: 0.85rem;
		letter-spacing: 0.05em;
	}

	.form__group input, 
	.form__group select, 
	.form__group textarea {
		padding: 1.2rem;
		border: 1px solid rgba(0,0,0,0.1);
		font-family: var(--font-main);
		font-size: 1rem;
		background-color: #fafafa;
		transition: var(--transition);
	}

	.form__group input:focus, 
	.form__group select:focus, 
	.form__group textarea:focus {
		outline: none;
		border-color: var(--color-black);
		background-color: var(--color-white);
		box-shadow: 4px 4px 0px var(--color-lime);
	}

	.error-msg {
		color: #e63946;
		font-weight: 700;
		margin-top: 1rem;
		text-align: center;
		font-size: 0.9rem;
	}

	.form-success {
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.5rem;
	}

	.success-icon {
		width: 60px;
		height: 60px;
		background-color: var(--color-lime);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2rem;
		font-weight: 900;
		margin-bottom: 1rem;
	}

	@media (max-width: 1024px) {
		.form-grid {
			grid-template-columns: 1fr;
			gap: 4rem;
		}
		.form-wrapper {
			padding: 2.5rem;
		}
	}
</style>
