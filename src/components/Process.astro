---
const steps = [
	{
		num: "01",
		title: "Діагностика",
		text: "Розбираємо задачу, бізнес-процес і точки, де втрачаються заявки."
	},
	{
		num: "02",
		title: "Структура",
		text: "Проєктуємо шлях клієнта, сторінки, форми, статуси та логіку."
	},
	{
		num: "03",
		title: "Розробка",
		text: "Збираємо сайт, бота, CRM або автоматизацію без зайвої складності."
	},
	{
		num: "04",
		title: "Запуск",
		text: "Публікуємо, тестуємо, підключаємо аналітику і передаємо в роботу."
	},
	{
		num: "05",
		title: "Підтримка",
		text: "Покращуємо те, що вже працює, і додаємо нові можливості."
	}
];
---
<section class="process">
	<div class="container">
		<h2 class="section-title">Як ми працюємо</h2>
		
		<div class="steps">
			{steps.map(step => (
				<div class="step">
					<div class="step__num">{step.num}</div>
					<div class="step__content">
						<h3 class="step__title">{step.title}</h3>
						<p class="step__text">{step.text}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.section-title {
		font-size: 3rem;
		margin-bottom: 3rem;
	}

	.steps {
		display: flex;
		flex-direction: column;
	}

	.step {
		display: flex;
		border-top: var(--border-width) solid var(--color-black);
		padding: 3rem 0;
		gap: 4rem;
	}

	.step:last-child {
		border-bottom: var(--border-width) solid var(--color-black);
	}

	.step__num {
		font-size: 4rem;
		font-weight: 800;
		line-height: 1;
		color: var(--color-lime);
		-webkit-text-stroke: 2px var(--color-black);
	}

	.step__title {
		font-size: 2rem;
		margin-bottom: 1rem;
	}

	.step__text {
		font-size: 1.2rem;
		font-weight: 500;
		max-width: 600px;
	}

	@media (max-width: 768px) {
		.step {
			flex-direction: column;
			gap: 1rem;
			padding: 2rem 0;
		}
		
		.step__num {
			font-size: 3rem;
		}
		
		.step__title {
			font-size: 1.5rem;
		}
	}
</style>
