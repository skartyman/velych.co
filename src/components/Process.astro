---
import Icon from './Icon.astro';

const steps = [
	{
		num: "01",
		title: "Діагностика",
		text: "Розбираємо задачу, бізнес-процес і точки, де втрачаються заявки.",
		icon: "diagnostics"
	},
	{
		num: "02",
		title: "Структура",
		text: "Проєктуємо шлях клієнта, сторінки, форми, статуси та логіку.",
		icon: "structure"
	},
	{
		num: "03",
		title: "Розробка",
		text: "Збираємо сайт, бота, CRM або автоматизацію без зайвої складності.",
		icon: "design"
	},
	{
		num: "04",
		title: "Запуск",
		text: "Публікуємо, тестуємо, підключаємо аналітику і передаємо в роботу.",
		icon: "launch"
	},
	{
		num: "05",
		title: "Підтримка",
		text: "Покращуємо те, що вже працює, і додаємо нові можливості.",
		icon: "support"
	}
];
---
<section class="process" id="process">
	<div class="container">
		<h2 class="section-title">Як ми працюємо</h2>
		
		<div class="steps-timeline">
			{steps.map(step => (
				<div class="step-card crosshair">
					<div class="step-card__header">
						<span class="step-card__num">{step.num}</span>
						<Icon name={step.icon as any} className="step-card__icon" />
					</div>
					<div class="step-card__content">
						<h3 class="step-card__title">{step.title}</h3>
						<p class="step-card__text">{step.text}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.section-title {
		font-size: clamp(2.5rem, 5vw, 4rem);
		margin-bottom: 5rem;
	}

	.steps-timeline {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 2px;
		background-color: rgba(0,0,0,0.1);
		border: 1px solid rgba(0,0,0,0.1);
	}

	.step-card {
		background-color: var(--color-milk);
		padding: 3rem;
		display: flex;
		flex-direction: column;
		gap: 2rem;
		transition: var(--transition);
	}

	.step-card:hover {
		background-color: var(--color-white);
		z-index: 1;
	}

	.step-card__header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
	}

	.step-card__num {
		font-size: 1.2rem;
		font-weight: 800;
		opacity: 0.3;
	}

	.step-card__icon {
		font-size: 2.5rem;
	}

	.step-card__title {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.step-card__text {
		font-size: 1rem;
		opacity: 0.7;
		font-weight: 500;
		line-height: 1.5;
	}

	@media (max-width: 768px) {
		.step-card {
			padding: 2rem;
		}
	}
</style>
