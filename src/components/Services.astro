---
import Icon from './Icon.astro';

const services = [
	{
		id: "website",
		title: "Веб-сайти",
		text: "Лендінги, сайти компаній, каталоги та промо-сторінки.",
		icon: "website"
	},
	{
		id: "bot",
		title: "Telegram-боти",
		text: "Заявки, автовідповіді, повідомлення менеджерам, міні-застосунки.",
		icon: "bot"
	},
	{
		id: "crm",
		title: "CRM та адмін-панелі",
		text: "Статуси, клієнти, задачі, ролі, історія та контроль процесів.",
		icon: "crm"
	},
	{
		id: "automation",
		title: "Автоматизація",
		text: "Google Sheets, API, Telegram, звіти та складні інтеграції.",
		icon: "automation"
	}
];
---
<section class="services section-dark">
	<div class="container">
		<div class="section-header">
			<h2 class="section-title">Що ми робимо</h2>
			<p class="section-subtitle">Розробляємо інструменти, які приносять результат</p>
		</div>
		
		<div class="services-grid">
			{services.map(service => (
				<div class="service-item crosshair">
					<div class="service-item__icon">
						<Icon name={service.icon as any} className="icon-lg" />
					</div>
					<h3 class="service-item__title">{service.title}</h3>
					<p class="service-item__text">{service.text}</p>
					<a href={`/posluhy#${service.id}`} class="service-item__link">Детальніше →</a>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.section-header {
		margin-bottom: 5rem;
		border-left: 4px solid var(--color-lime);
		padding-left: 2rem;
	}

	.section-title {
		font-size: clamp(2.5rem, 6vw, 4rem);
		margin-bottom: 1rem;
	}

	.section-subtitle {
		font-size: 1.2rem;
		opacity: 0.6;
		text-transform: uppercase;
		font-weight: 700;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		border: 1px solid rgba(255,255,255,0.1);
	}

	.service-item {
		padding: 4rem;
		border: 1px solid rgba(255,255,255,0.1);
		transition: var(--transition);
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.service-item:hover {
		background-color: rgba(200, 255, 0, 0.05);
	}

	.icon-lg {
		font-size: 3.5rem;
	}

	.service-item__title {
		font-size: 2rem;
	}

	.service-item__text {
		font-size: 1.1rem;
		opacity: 0.7;
		line-height: 1.5;
	}

	.service-item__link {
		margin-top: auto;
		font-weight: 800;
		text-transform: uppercase;
		font-size: 0.9rem;
		color: var(--color-lime);
	}

	@media (max-width: 768px) {
		.service-item {
			padding: 2.5rem;
		}
	}
</style>
