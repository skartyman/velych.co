---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Українська веб-компанія. Робимо сайти, Telegram-боти, CRM та автоматизацію для заявок, клієнтів і процесів." } = Astro.props;
---

<!doctype html>
<html lang="uk">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="noise-overlay"></div>
		<slot />
		
		<a href="#form" class="mobile-cta-sticky btn btn-primary">
			Обговорити проєкт <span class="arrow">→</span>
		</a>

		<style is:global>
			:root {
				--color-black: #080808;
				--color-white: #ffffff;
				--color-milk: #f3f1ea;
				--color-lime: #c8ff00;
				--color-dark: #070707;
				--font-main: 'Space Grotesk', sans-serif;
				--border-width: 1px;
				--transition: 0.2s cubic-bezier(0.23, 1, 0.32, 1);
			}

			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				background-color: var(--color-milk);
				color: var(--color-black);
				font-family: var(--font-main);
				line-height: 1.4;
				overflow-x: hidden;
				-webkit-font-smoothing: antialiased;
			}

			h1, h2, h3, h4, h5, h6 {
				text-transform: uppercase;
				font-weight: 800;
				letter-spacing: -0.04em;
				line-height: 0.9;
			}

			a {
				color: inherit;
				text-decoration: none;
				transition: var(--transition);
			}

			.noise-overlay {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				pointer-events: none;
				opacity: 0.04;
				z-index: 9999;
				background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
			}

			.container {
				max-width: 1440px;
				margin: 0 auto;
				padding: 0 40px;
			}

			@media (max-width: 768px) {
				.container {
					padding: 0 20px;
				}
			}

			/* Utility Classes */
			.section-dark {
				background-color: var(--color-dark);
				color: var(--color-white);
				position: relative;
			}

			.section-dark .noise-overlay {
				opacity: 0.08;
			}

			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 1.2rem 2.5rem;
				font-weight: 800;
				text-transform: uppercase;
				border: var(--border-width) solid var(--color-black);
				background-color: var(--color-white);
				cursor: pointer;
				font-size: 1rem;
				letter-spacing: 0.02em;
				gap: 0.8rem;
			}

			.btn:hover {
				background-color: var(--color-lime);
				transform: translate(-4px, -4px);
				box-shadow: 4px 4px 0px var(--color-black);
			}

			.btn-primary {
				background-color: var(--color-lime);
				box-shadow: 4px 4px 0px var(--color-black);
			}

			.btn-primary:hover {
				background-color: var(--color-white);
			}

			.btn-dark {
				background-color: var(--color-black);
				color: var(--color-white);
				border-color: var(--color-white);
			}

			.btn-dark:hover {
				background-color: var(--color-lime);
				color: var(--color-black);
				box-shadow: 4px 4px 0px var(--color-white);
			}

			.brutal-card {
				border: var(--border-width) solid var(--color-black);
				padding: 2.5rem;
				background-color: var(--color-white);
				transition: var(--transition);
			}

			.brutal-card:hover {
				background-color: var(--color-lime);
				transform: translate(-4px, -4px);
				box-shadow: 4px 4px 0px var(--color-black);
			}

			.corner-bracket {
				position: relative;
			}

			.corner-bracket::before, .corner-bracket::after {
				content: '';
				position: absolute;
				width: 20px;
				height: 20px;
				border: 2px solid var(--color-lime);
			}

			.corner-bracket::before {
				top: -10px;
				left: -10px;
				border-right: 0;
				border-bottom: 0;
			}

			.corner-bracket::after {
				bottom: -10px;
				right: -10px;
				border-left: 0;
				border-top: 0;
			}

			.crosshair {
				position: relative;
			}

			.crosshair::before, .crosshair::after {
				content: '';
				position: absolute;
				background-color: var(--color-lime);
				opacity: 0.5;
			}

			.crosshair::before {
				top: 50%;
				left: -20px;
				right: -20px;
				height: 1px;
			}

			.crosshair::after {
				left: 50%;
				top: -20px;
				bottom: -20px;
				width: 1px;
			}

			.section-divider {
				height: var(--border-width);
				background-color: var(--color-black);
				width: 100%;
				opacity: 0.1;
			}

			.outline-badge {
				display: inline-block;
				border: 1px solid currentColor;
				padding: 0.3rem 0.8rem;
				border-radius: 20px;
				font-size: 0.8rem;
				font-weight: 700;
				text-transform: uppercase;
			}

			.lime-dot {
				display: inline-block;
				width: 8px;
				height: 8px;
				background-color: var(--color-lime);
				border-radius: 50%;
				margin-right: 0.5rem;
			}

			section {
				padding: 8rem 0;
				border-bottom: var(--border-width) solid rgba(0,0,0,0.1);
			}

			.mobile-cta-sticky {
				display: none;
				position: fixed;
				bottom: 20px;
				left: 20px;
				right: 20px;
				z-index: 1001;
				width: calc(100% - 40px);
				box-shadow: 0 10px 30px rgba(0,0,0,0.2);
			}

			@media (max-width: 768px) {
				section {
					padding: 5rem 0;
				}
				.mobile-cta-sticky {
					display: flex;
				}
				.btn {
					width: 100%;
				}
			}
		</style>
	</body>
</html>
