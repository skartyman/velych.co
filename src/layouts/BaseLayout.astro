---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Українська веб-компанія. Робимо сайти, Telegram-боти, CRM та автоматизацію для заявок, клієнтів і процесів." } = Astro.props;
---

<!doctype html>
<html lang="uk">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="noise-overlay"></div>
		<slot />
		
		<button id="sticky-cta" class="mobile-cta-sticky btn btn-primary">
			Обговорити проєкт <span class="arrow">→</span>
		</button>

		<script>
			const stickyCta = document.getElementById('sticky-cta');
			stickyCta?.addEventListener('click', () => {
				const formElement = document.getElementById('form');
				if (formElement) {
					formElement.scrollIntoView({ behavior: 'smooth' });
				} else {
					window.location.href = '/kontakty#form';
				}
			});
		</script>

		<style is:global>
			:root {
				--color-black: #080808;
				--color-white: #ffffff;
				--color-milk: #f3f1ea;
				--color-lime: #c8ff00;
				--color-dark: #070707;
				--font-main: 'Space Grotesk', sans-serif;
				--border-width: 1px;
				--transition: 0.3s cubic-bezier(0.23, 1, 0.32, 1);
			}

			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				background-color: var(--color-milk);
				color: var(--color-black);
				font-family: var(--font-main);
				line-height: 1.3;
				overflow-x: hidden;
				-webkit-font-smoothing: antialiased;
			}

			body.menu-open {
				overflow: hidden;
			}

			h1, h2, h3, h4, h5, h6 {
				text-transform: uppercase;
				font-weight: 800;
				letter-spacing: -0.05em;
				line-height: 0.85;
			}

			p {
				line-height: 1.5;
			}

			a {
				color: inherit;
				text-decoration: none;
				transition: var(--transition);
			}

			.noise-overlay {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				pointer-events: none;
				opacity: 0.04;
				z-index: 9999;
				background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
			}

			.container {
				max-width: 1440px;
				margin: 0 auto;
				padding: 0 40px;
			}

			@media (max-width: 768px) {
				.container {
					padding: 0 20px;
				}
			}

			/* Brutal UI Utility Classes */
			.section-dark {
				background-color: var(--color-dark);
				color: var(--color-white);
			}

			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 1rem 1.8rem;
				font-weight: 800;
				text-transform: uppercase;
				border: var(--border-width) solid var(--color-black);
				background-color: var(--color-white);
				cursor: pointer;
				font-size: 0.9rem;
				letter-spacing: 0.05em;
				gap: 0.8rem;
				transition: var(--transition);
			}

			.btn:hover {
				background-color: var(--color-lime);
				transform: translate(-2px, -2px);
				box-shadow: 4px 4px 0px var(--color-black);
			}

			.btn-primary {
				background-color: var(--color-lime);
			}

			.btn-dark {
				background-color: var(--color-black);
				color: var(--color-white);
				border-color: var(--color-white);
			}

			.btn-dark:hover {
				background-color: var(--color-lime);
				color: var(--color-black);
				box-shadow: 4px 4px 0px var(--color-white);
			}

			.brutal-card {
				border: var(--border-width) solid var(--color-black);
				padding: 2.5rem;
				background-color: var(--color-white);
				transition: var(--transition);
			}

			.corner-bracket {
				position: relative;
			}

			.corner-bracket::before, .corner-bracket::after {
				content: '';
				position: absolute;
				width: 15px;
				height: 15px;
				border: 1px solid var(--color-black);
				opacity: 0.3;
			}

			.corner-bracket::before { top: 0; left: 0; border-right: 0; border-bottom: 0; }
			.corner-bracket::after { bottom: 0; right: 0; border-left: 0; border-top: 0; }

			.outline-badge {
				display: inline-block;
				border: 1px solid var(--color-black);
				padding: 0.4rem 1rem;
				border-radius: 50px;
				font-size: 0.75rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin-bottom: 1.5rem;
			}

			.section-dark .outline-badge {
				border-color: rgba(255,255,255,0.3);
			}

			.lime-dot {
				display: inline-block;
				width: 10px;
				height: 10px;
				background-color: var(--color-lime);
				border-radius: 50%;
			}

			section {
				padding: 6rem 0;
				border-bottom: var(--border-width) solid rgba(0,0,0,0.08);
			}

			.mobile-cta-sticky {
				display: none;
				position: fixed;
				bottom: 20px;
				left: 20px;
				right: 20px;
				z-index: 1001;
				width: calc(100% - 40px);
				box-shadow: 0 10px 30px rgba(0,0,0,0.2);
			}

			@media (max-width: 768px) {
				section {
					padding: 4rem 0;
				}
				.mobile-cta-sticky {
					display: flex;
				}
			}

			/* Typography helpers */
			.text-stroke {
				color: transparent;
				-webkit-text-stroke: 1px var(--color-black);
			}
			.section-dark .text-stroke {
				-webkit-text-stroke: 1px var(--color-white);
			}

			.bg-lime {
				background-color: var(--color-lime);
				padding: 0 0.1em;
			}
		</style>
	</body>
</html>
