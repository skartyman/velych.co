---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Icon from '../components/Icon.astro';
import LeadForm from '../components/LeadForm.astro';
import Footer from '../components/Footer.astro';

const faqs = [
	{ q: "СКІЛЬКИ КОШТУЄ ПРОЄКТ?", a: "Усе залежить від задачі. Оцінка після короткого брифу — безкоштовно." },
	{ q: "СКІЛЬКИ ЧАСУ ЗАЙМАЄ РОЗРОБКА?", a: "Сайт — від 2 тижнів, бот — від 1 тижня, CRM та автоматизація — індивідуально." },
	{ q: "ЯК ПОЧАТИ СПІВПРАЦЮ?", a: "Заповніть форму або напишіть у Telegram — ми відповімо та запропонуємо план дій." }
];
---

<BaseLayout title="Контакти — VELYCH.CO">
	<Header />
	
	<main>
		<section class="page-hero">
			<div class="container hero-grid">
				<div class="hero-content">
					<h1 class="page-title">ОБГОВОРИМО ПРОЄКТ</h1>
					<p class="hero-subtitle">Коротко опишіть задачу — ми скажемо, як це реалізувати.</p>
				</div>
				<div class="hero-visual">
					<div class="cube-wrapper corner-bracket">
						<img src="/images/brand/concrete-cube.webp" alt="Cube" class="hero-cube" />
						<div class="cube-label">// 01</div>
					</div>
				</div>
			</div>
		</section>

		<LeadForm />

		<section class="secondary-contacts">
			<div class="container">
				<div class="contacts-bar">
					<a href="https://t.me/velych_co" class="contact-card brutal-card">
						<Icon name="bot" />
						<div class="c-info">
							<strong>TELEGRAM</strong>
							<span>Найшвидший спосіб зв'язку</span>
							<p>@velych_co</p>
						</div>
					</a>
					<a href="mailto:hello@velych.pp.ua" class="contact-card brutal-card">
						<Icon name="support" />
						<div class="c-info">
							<strong>EMAIL</strong>
							<span>Пишіть на пошту — відповімо за день</span>
							<p>hello@velych.pp.ua</p>
						</div>
					</a>
					<div class="contact-card brutal-card">
						<Icon name="automation" />
						<div class="c-info">
							<strong>ШВИДКИЙ ДЗВІНОК</strong>
							<span>Залиште номер — передзвонимо</span>
							<a href="#" class="call-link">Замовити дзвінок</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="faq-section">
			<div class="container">
				<div class="faq-header">
					<h2 class="faq-title">ПОШИРЕНІ ПИТАННЯ</h2>
					<div class="faq-note corner-bracket">НЕ ЛЮБИМО ВОДУ.<br/>ЛЮБИМО СУТЬ.</div>
				</div>

				<div class="faq-grid">
					{faqs.map(item => (
						<div class="faq-item">
							<h3>{item.q}</h3>
							<p>{item.a}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="bottom-strip section-dark">
			<div class="container">
				<div class="strip-content">
					<p>ПРАЦЮЄМО З КЛІЄНТАМИ В УКРАЇНІ ТА ЄВРОПІ <span class="lime-dot"></span> КИЇВ • ДНІПРО • ВІДДАЛЕНО</p>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</BaseLayout>

<style>
	.page-hero { padding: 4rem 0; }
	.hero-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; align-items: center; gap: 4rem; }
	.page-title { font-size: clamp(3rem, 10vw, 7.5rem); margin-bottom: 1.5rem; }
	.hero-subtitle { font-size: 1.2rem; font-weight: 800; opacity: 0.6; }

	.hero-visual { display: flex; justify-content: flex-end; position: relative; }
	.hero-cube { max-width: 100%; mix-blend-mode: multiply; filter: grayscale(1); }
	.cube-label { position: absolute; top: 0; right: 0; font-weight: 800; opacity: 0.3; }

	.secondary-contacts { padding: 4rem 0; border-top: 1px solid rgba(0,0,0,0.1); }
	.contacts-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
	.contact-card { display: flex; gap: 2rem; align-items: center; padding: 3rem; }
	.c-info strong { display: block; font-size: 0.75rem; letter-spacing: 0.1em; opacity: 0.4; margin-bottom: 0.5rem; }
	.c-info span { display: block; font-size: 0.85rem; margin-bottom: 0.5rem; font-weight: 500; }
	.c-info p, .c-info .call-link { font-size: 1.2rem; font-weight: 800; border-bottom: 2px solid var(--color-black); }

	.faq-header { padding: 8rem 0 4rem; display: flex; justify-content: space-between; align-items: flex-end; }
	.faq-title { font-size: clamp(3rem, 8vw, 6rem); }
	.faq-note { padding: 1rem; font-size: 0.8rem; font-weight: 800; opacity: 0.6; }

	.faq-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 3px; background-color: rgba(0,0,0,0.1); border: 1px solid rgba(0,0,0,0.1); }
	.faq-item { background-color: var(--color-milk); padding: 3rem; display: flex; flex-direction: column; gap: 1.5rem; }
	.faq-item h3 { font-size: 1.1rem; line-height: 1.2; }
	.faq-item p { font-size: 0.95rem; opacity: 0.7; font-weight: 500; }

	.bottom-strip { padding: 1.5rem 0; font-size: 0.75rem; font-weight: 800; letter-spacing: 0.05em; text-align: center; }

	@media (max-width: 1024px) {
		.hero-grid { grid-template-columns: 1fr; }
		.hero-visual { justify-content: center; margin: 0 auto; max-width: 300px; }
		.faq-header { flex-direction: column; align-items: flex-start; gap: 2rem; }
	}
</style>
