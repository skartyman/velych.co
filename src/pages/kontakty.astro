---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import LeadForm from '../components/LeadForm.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Контакти — VELYCH.CO">
	<Header />
	<main>
		<section class="contacts-hero">
			<div class="container">
				<div class="outline-badge">Зв'язок</div>
				<h1 class="page-title">Контакти</h1>
				
				<div class="contacts-grid">
					<div class="brutal-card contact-card">
						<span class="contact-card__label">Email</span>
						<a href="mailto:hello@velych.pp.ua" class="contact-card__value">hello@velych.pp.ua</a>
					</div>
					<div class="brutal-card contact-card">
						<span class="contact-card__label">Telegram</span>
						<span class="contact-card__value">@velych_co</span>
					</div>
					<div class="brutal-card contact-card card-lime">
						<span class="contact-card__label">Локація</span>
						<span class="contact-card__value">Україна · Віддалено</span>
					</div>
				</div>
			</div>
		</section>

		<LeadForm />
	</main>
	<Footer />
</BaseLayout>

<style>
	.contacts-hero {
		padding: 10rem 0 6rem;
	}
	.page-title {
		font-size: clamp(3rem, 8vw, 6rem);
		margin: 2rem 0 4rem;
	}
	.contacts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}
	.contact-card {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		min-height: 200px;
		justify-content: center;
	}
	.contact-card__label {
		font-size: 0.8rem;
		text-transform: uppercase;
		font-weight: 800;
		opacity: 0.4;
		letter-spacing: 0.1em;
	}
	.contact-card__value {
		font-size: 1.8rem;
		font-weight: 700;
		word-break: break-all;
	}
	.card-lime {
		background-color: var(--color-lime);
		border: none;
	}
	@media (max-width: 768px) {
		.contact-card {
			min-height: auto;
			padding: 2rem;
		}
		.contact-card__value {
			font-size: 1.4rem;
		}
	}
</style>
