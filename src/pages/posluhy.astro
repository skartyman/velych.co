---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Services from '../components/Services.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Послуги — VELYCH.CO">
	<Header />
	<main>
		<section class="page-hero section-dark">
			<div class="container">
				<div class="outline-badge">Що ми робимо</div>
				<h1 class="page-title">Наші Послуги</h1>
				<p class="page-subtitle">Робимо те, що працює. Без зайвого шуму та складних термінів.</p>
			</div>
		</section>
		<Services />
	</main>
	<Footer />
</BaseLayout>

<style>
	.page-hero {
		padding: 10rem 0 6rem;
	}
	.page-title {
		font-size: clamp(3rem, 8vw, 6rem);
		margin: 2rem 0;
	}
	.page-subtitle {
		font-size: 1.5rem;
		font-weight: 500;
		max-width: 600px;
		opacity: 0.8;
	}
</style>
