---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Icon from '../components/Icon.astro';
import Footer from '../components/Footer.astro';

const projects = [
	{
		title: "SURPRESSO SERVICE",
		tag: "ВЕБ-САЙТ",
		task: "Створити сайт, який викликає довіру і генерує заявки на ремонт кавомашин.",
		what: "Розробили швидкий сайт з чіткою структурою, формою заявки та інтеграцією з CRM.",
		result: "ЗАЯВКИ В ОДНОМУ МІСЦІ. +47% конверсії у заявку за перший місяць роботи сайту.",
		image: "/images/brand/concrete-cube.webp" // Using cube as placeholder if no actual screenshot
	},
	{
		title: "GORPLIAZH",
		tag: "ВЕБ-САЙТ",
		task: "Оновити сайт бази відпочинку та автоматизувати прийом бронювань.",
		what: "Переробили дизайн, додали модуль бронювання, інтегрували оплату та повідомлення.",
		result: "МЕНШЕ РУЧНОЇ РУТИНИ. -70% ручної роботи менеджерів з бронюваннями.",
		image: "/images/brand/concrete-cube.webp"
	},
	{
		title: "MINI APP / SERVICE FLOW",
		tag: "МІНІ-ДОДАТОК",
		task: "Прискорити обробку заявок і статусів у сервісному відділі.",
		what: "Створили Telegram Mini App з логікою, статусами та сповіщеннями для клієнтів і майстрів.",
		result: "ШВИДКИЙ ЗАПУСК. Запуск процесу з заявки ускорився в 2.3 рази.",
		image: "/images/brand/concrete-cube.webp"
	}
];

const stats = [
	{ icon: "diagnostics", val: "60+", label: "ПРОЄКТІВ ЗАПУЩЕНО\nдля бізнесу в Україні та Європі" },
	{ icon: "structure", val: "8+ РОКІВ", label: "ДОСВІДУ В РОЗРОБЦІ\nбез зайвих слів і презентацій" },
	{ icon: "design", val: "5.0", label: "РЕЙТИНГ НА CLUTCH\nна основі відгуків клієнтів" },
	{ icon: "launch", val: "90%", label: "КЛІЄНТІВ ПОВЕРТАЮТЬСЯ\nза новими задачами" }
];
---

<BaseLayout title="Проєкти — VELYCH.CO">
	<Header />
	
	<main>
		<section class="page-hero">
			<div class="container hero-grid">
				<div class="hero-content">
					<h1 class="page-title">ПРОЄКТИ</h1>
					<p class="hero-subtitle">КЕЙСИ, ДЕ КОД ВИРІШУЄ БІЗНЕС-ЗАВДАННЯ.</p>
				</div>
				<div class="hero-visual">
					<div class="cube-wrapper corner-bracket">
						<img src="/images/brand/concrete-cube.webp" alt="Cube" class="hero-cube" />
						<div class="cube-label">// 01</div>
					</div>
				</div>
			</div>
		</section>

		<section class="projects-list">
			<div class="container">
				{projects.map(p => (
					<div class="project-card">
						<div class="project-card__visual">
							<img src={p.image} alt={p.title} class="project-img" />
						</div>
						<div class="project-card__content">
							<div class="project-card__header">
								<h2 class="project-title">{p.title}</h2>
								<span class="project-tag outline-badge">{p.tag}</span>
								<a href="#" class="btn-view">ПЕРЕГЛЯНУТИ ПРОЄКТ →</a>
							</div>
							
							<div class="project-details">
								<div class="p-detail">
									<Icon name="diagnostics" />
									<div>
										<strong>ЗАДАЧА</strong>
										<p>{p.task}</p>
									</div>
								</div>
								<div class="p-detail">
									<Icon name="design" />
									<div>
										<strong>ЩО ЗРОБИЛИ</strong>
										<p>{p.what}</p>
									</div>
								</div>
								<div class="p-detail highlight">
									<Icon name="launch" />
									<div>
										<strong>РЕЗУЛЬТАТ</strong>
										<p><span class="bg-lime">{p.result}</span></p>
									</div>
								</div>
							</div>
						</div>
					</div>
				))}
			</div>
		</section>

		<section class="stats-bar section-dark">
			<div class="container">
				<div class="stats-grid">
					{stats.map(s => (
						<div class="stat-item">
							<Icon name={s.icon as any} className="stat-icon" />
							<div class="stat-val">{s.val}</div>
							<div class="stat-label">{s.label}</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="bottom-cta-dark section-dark">
			<div class="container">
				<div class="cta-strip corner-bracket">
					<h2 class="cta-text">ХОЧЕТЕ ТАК САМО?<br/><span class="text-lime">ОБГОВОРИМО ВАШ ПРОЄКТ.</span></h2>
					<p>Без зобов'язань. Просто розмова про те, як ми можемо бути корисні.</p>
					<div class="cta-btns">
						<a href="/kontakty#form" class="btn btn-primary">ОБГОВОРИТИ ПРОЄКТ <span class="arrow">→</span></a>
						<a href="https://t.me/velych_co" class="btn btn-outline">НАПИСАТИ У TELEGRAM</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</BaseLayout>

<style>
	.page-hero { padding: 4rem 0; border-bottom: 1px solid rgba(0,0,0,0.1); }
	.hero-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; align-items: center; gap: 4rem; }
	.page-title { font-size: clamp(4rem, 12vw, 8.5rem); margin-bottom: 1rem; }
	.hero-subtitle { font-size: 1.2rem; font-weight: 800; opacity: 0.8; }
	
	.hero-visual { display: flex; justify-content: flex-end; position: relative; }
	.hero-cube { max-width: 100%; mix-blend-mode: multiply; filter: grayscale(1); }
	.cube-label { position: absolute; top: 0; right: 0; font-weight: 800; opacity: 0.3; }

	.project-card {
		display: grid;
		grid-template-columns: 350px 1fr;
		gap: 3rem;
		padding: 4rem 0;
		border-bottom: 1px solid rgba(0,0,0,0.1);
	}

	.project-img { width: 100%; border: 1px solid rgba(0,0,0,0.1); filter: grayscale(1); }

	.project-card__header {
		display: flex;
		align-items: center;
		gap: 2rem;
		margin-bottom: 3rem;
	}

	.project-title { font-size: 2.2rem; }
	.project-tag { margin-bottom: 0; }
	.btn-view { margin-left: auto; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; border-bottom: 2px solid var(--color-black); }

	.project-details {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.p-detail { display: flex; gap: 1rem; flex-direction: column; }
	.p-detail strong { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.4; }
	.p-detail p { font-size: 0.95rem; font-weight: 600; }
	.highlight .bg-lime { padding: 0 0.2em; color: var(--color-black); }

	.stats-bar { padding: 6rem 0; border-top: 1px solid rgba(255,255,255,0.1); }
	.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 3rem; }
	.stat-item { display: flex; flex-direction: column; gap: 1rem; }
	.stat-icon { font-size: 2rem; }
	.stat-val { font-size: 2.5rem; font-weight: 800; }
	.stat-label { font-size: 0.75rem; font-weight: 700; white-space: pre-line; opacity: 0.5; text-transform: uppercase; }

	.bottom-cta-dark { padding: 10rem 0; text-align: center; }
	.cta-strip { padding: 6rem 2rem; background-color: #0c0c0c; }
	.cta-text { font-size: clamp(2rem, 6vw, 4rem); margin-bottom: 1rem; }
	.text-lime { color: var(--color-lime); }
	.cta-btns { display: flex; justify-content: center; gap: 2rem; margin-top: 3rem; }
	.btn-outline { background: transparent; border-color: rgba(255,255,255,0.2); }

	@media (max-width: 1024px) {
		.hero-grid { grid-template-columns: 1fr; }
		.project-card { grid-template-columns: 1fr; gap: 2rem; }
		.project-details { grid-template-columns: 1fr; }
		.project-card__header { flex-direction: column; align-items: flex-start; gap: 1rem; }
		.btn-view { margin-left: 0; }
	}

	@media (max-width: 768px) {
		.cta-btns { flex-direction: column; }
	}
</style>
