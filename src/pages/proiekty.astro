---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Проєкти — VELYCH.CO">
	<Header />
	<main>
		<section class="stub section-dark">
			<div class="container">
				<div class="outline-badge">Кейси</div>
				<h1 class="page-title">Наші Проєкти</h1>
				<div class="brutal-card stub__card">
					<p>Кейси скоро з’являться.<br/>Зараз ми працюємо над новими інструментами.</p>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>

<style>
	.stub {
		min-height: 80vh;
		display: flex;
		align-items: center;
	}
	.page-title {
		font-size: clamp(3rem, 8vw, 6rem);
		margin: 2rem 0;
	}
	.stub__card {
		padding: 6rem;
		background-color: var(--color-lime);
		color: var(--color-black);
		font-size: 2rem;
		font-weight: 800;
		text-transform: uppercase;
		text-align: center;
		border: none;
	}
</style>
